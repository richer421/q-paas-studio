# ============================================================
# Q-PaaS 基建服务通用配置
# ============================================================

# 部署模式：auto | compose | helm（auto 自动检测环境）
DEPLOY_MODE=auto

# Kubernetes 命名空间（Helm 部署时使用）
INFRA_NAMESPACE=q-infra

# 网络名称（Docker Compose 部署时使用）
COMPOSE_NETWORK=q-infra-net

# ============================================================
# Jenkins 配置
# ============================================================
JENKINS_PORT=8090
JENKINS_AGENT_PORT=50000
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=changeme
JENKINS_IMAGE=jenkins/jenkins:lts-jdk17
JENKINS_MEMORY_LIMIT=2g

# ============================================================
# Harbor 配置
# ============================================================
HARBOR_PORT=8880
HARBOR_ADMIN_PASSWORD=Harbor12345
HARBOR_DB_PASSWORD=changeme
HARBOR_VERSION=v2.11.0

# ============================================================
# GitLab 配置
# ============================================================
GITLAB_PORT=8929
GITLAB_SSH_PORT=2224
GITLAB_ROOT_PASSWORD=changeme123
GITLAB_EXTERNAL_URL=http://localhost:8929
GITLAB_IMAGE=gitlab/gitlab-ce:latest
GITLAB_MEMORY_LIMIT=4g

# ============================================================
# MySQL 配置
# ============================================================
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=appdb

# ============================================================
# Redis 配置
# ============================================================
REDIS_AUTH_ENABLED=true
REDIS_PASSWORD=redis123

# ============================================================
# PostgreSQL 配置
# ============================================================
POSTGRES_PASSWORD=postgres123
POSTGRES_DATABASE=appdb

# ============================================================
# MinIO 配置
# ============================================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123
